{
  "name": "guild-wars",
  "productName": "Guild Wars",
  "version": "0.0.1-alpha.1",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "type": "module",
  "description": "Guild Wars for macOS",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mat4m0/gwonmac.git"
  },
  "bugs": {
    "url": "https://github.com/Mat4m0/gwonmac/issues"
  },
  "main": "build/main/main.js",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "pnpm build && electron-forge start",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.renderer.json",
    "lint": "eslint .",
    "test:unit": "node --import ./tests/ts-hook.mjs --experimental-strip-types --test tests/unit/*.ts",
    "test:integration": "pnpm build && node --test tests/integration/*.mjs",
    "test:electron": "pnpm build && playwright test --config=tests/electron/playwright.config.mjs",
    "test:packaged": "node tests/packaged-smoke.mjs",
    "test:release": "pnpm build && node --test tests/release/*.mjs",
    "test:website": "pnpm --filter gw-website typecheck && pnpm --filter gw-website generate && pnpm --filter gw-website build && node tests/website-smoke.mjs",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:electron",
    "package": "pnpm build && node scripts/clean-output.mjs && electron-forge package",
    "make": "pnpm build && node scripts/clean-output.mjs && electron-forge make",
    "diagnostics:validate": "tsc && node build/tools/diagnostics/validate.js",
    "diagnostics:summarize": "tsc && node build/tools/diagnostics/summarize.js",
    "diagnostics:compare": "tsc && node build/tools/diagnostics/compare.js",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:release && pnpm test:website && pnpm package && pnpm test:packaged"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron/fuses": "^2.1.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.13.3",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "electron": "^43.2.0",
    "eslint": "^10.7.0",
    "playwright": "^1.55.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0"
  }
}
