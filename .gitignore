# Credentials and private diagnostics ------------------------------------
# access.key can be extracted by gwkey.py for offline analysis. The runtime
# uses the public client key in source; neither private data nor exports belong
# in git.
access.key
*.key
credentials.bin
*.gwdiag
*.dmp

# Game artifacts ----------------------------------------------------------
# ArenaNet's copyrighted binaries. Never commit these. Everything here is
# reproducible from ArenaNet's public client distribution.
*.apk
*.wasm
*.wasm.debug
Gw.js
Gw.jspi.js
Gw.snapshot
manifest.json
version.json

# Legacy/local chunk cache -- content-addressed pieces of the above.
gwpatch-cache/

# Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
.venv/
venv/

# Dependencies and local tooling.
node_modules/
package-lock.json

# Release packaging, assembled by .github/workflows/release.yml.
dist-release/

# Build output -- everything under here is derived from your own client copy.
# Directory-shaped, because the file patterns above missed
# dist/snapshot-chunks.json (16k ArenaNet content hashes) and it got published.
dist/

# Electron / TypeScript build and Forge packaging.
# tsc emits to build/; Forge packages to out/ — keep them separate.
build/
out/
.pnpm-store/
.vite/
.webpack/
out-tsc/
forge-dist/
*.tsbuildinfo
playwright-report/
test-results/
.eslintcache

# macOS metadata.
.DS_Store
.nuxt
.output
